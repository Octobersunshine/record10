{
  "type": "object",
  "properties": {
    "id": { "type": "string", "pattern": "^ORD-\\d+$" },
    "customer": {
      "$ref": "customer_schema.json"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "product_schema.json" }
    },
    "total": { "type": "number", "minimum": 0 }
  },
  "required": ["id", "items", "total"]
}
